#!/bin/sh

SCRIPT_PATH=$HOME/.config/hypr/scripts
export PATH="$SCRIPT_PATH:$PATH"
terminal-pgm=kitty

menu() {
    local menu_font="Hack Nerd Font 14"
    local menu_width="390px"
    local menu_height="600px"

    local theme_str="prompt{enabled:false;} entry{placeholder:\"$1...\";} window{width:$menu_width;height:$menu_height;font:'$menu_font';}"

    echo -e "$2" | rofi -dmenu -i -markup-rows -format p -theme-str "$theme_str" -p ""

}

terminal() {
    kitty --class hypr-sys-menu --title=Fedora bash -c "$1"
}

present_terminal() {
    local cmd="$*"
    kitty --class hypr-sys-menu bash -c "hypr-show-logo; $cmd; hypr-show-done"
}

edit_file() {
    notify-send -u low "Editing config file" "$1"
    kitty nvim "$1"
}

back_to() {
    "$1"
}

webapp() {
    brave-browser --password-store=basic --new-window --app=$1
    # flatpak run com.brave.Browser --password-store=basic --new-window --app=$1
}

show_learn_menu() {
    case $(menu "Learn" "´ä£  Keybindings\n´Éà  Omarchy\n´ìÖ  Hyprland\n´ìò  Bspwm\n¯»Â  Waybar\n¯»Â  Polybar\n´é»  NerdFonts\n¾░úç  Arch\n¯Ü«  Neovim\n¾▒åâ  Bash") in
        *Keybindings*) hypr-show-keybinds ;;
        *Omarchy*)     webapp "https://manuals.omamix.org/2/the-omarchy-manual" ;;
        *Hyprland*)    webapp "https://wiki.hypr.land/" ;;
        *Bspwm*)       webapp "https://github.com/baskerville/bspwm/wiki" ;;
        *Waybar*)      webapp "https://github.com/Alexays/Waybar/wiki" ;;
        *Polybar*)     webapp "https://github.com/polybar/polybar/wiki" ;;
        *NerdFonts*)   webapp "https://www.nerdfonts.com/cheat-sheet" ;;
        *Arch*)        webapp "https://wiki.archlinux.org/title/Main_page" ;;
        *Bash*)        webapp "https://devhints.io/bash" ;;
        *Neovim*)      webapp "https://www.lazyvim.org/keymaps" ;;
        *) show_main_menu ;;
    esac
}

show_trigger_menu() {
    case "$(menu "Trigger" "´Ç░  Capture\n´êà  Toggle")" in
        *Capture*) show_capture_menu ;;
        *Toggle*)  show_toggle_menu ;;
        *) show_main_menu ;;
    esac
}

show_capture_menu() {
    case $(menu "Capture" "´Ç░  Screenshot\n´Ç¢  Screenrecord\n¾░âë  Color") in
        *Screenshot*)   show_screenshot_menu ;;
        *Screenrecord*) show_screenrecord_menu ;;
        *Color*)        pkill hyprpicker || hyprpicker -a ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_screenshot_menu() {
    case $(menu "Screenshot" "¾░®¼   Region to clipboard\n¾░®¼   Region to file\n¾░╣æ    Display to clipboard\n¾░╣æ    Display to file") in
        *Region\ to\ clipboard*) hypr-cmd-screenshot clipboard ;;
        *Region\ to\ file*)      hypr-cmd-screenshot region ;;
        *Display\ to\ file*)     hypr-cmd-screenshot ;;
        *) show_capture_menu ;;
    esac
}

show_screenrecord_menu() {
    case $(menu "Screenrecord" "¾░®¼  Region\n¾░╣æ  Display") in
        *Region*)  $OMARCHY_BIN_PATH/omarchy-cmd-screenrecord ;;
        *Display*) $OMARCHY_BIN_PATH/omarchy-cmd-screenrecord output ;;
        *) show_capture_menu ;;
    esac
}

show_toggle_menu() {
    # wifi_status=$(nmcli radio wifi)
    # bt_status=$(if $(bluetoothctl show | grep -q "Powered: no" > /dev/null ); then echo "disabled"; else echo "enabled"; fi)
    # power_status=$(tuned-adm active | cut -d " " -f 4)
    # keyb_status=$(setxkbmap -query | grep layout | awk '{print $2}')
    case $(menu "Toggle" "´ç½  Wifi\n¾░é»  Bluetooth\n´âº  Power Management\n´ä£  Keyboard Layout\n¾░¬ø  Keyboard ControlCaps\n¾▒ää  Screensaver\n¾░öÄ  Nightlight\n¾▒½û  Idle Lock\n¾░ì£  Top Bar") in
        *Wifi*)                  hypr-switch-wifi ;;
        *Bluetooth*)             hypr-bluetooth --toggle ;;
        *Power\ Management*)     hypr-switch-power-mgmt ;;
        *Keyboard\ Layout*)      hypr-switch-keyboard-layout ;;
        *Keyboard\ ControlCaps*) hypr-switch-controlcaps ;;
        *Nightlight*)            hypr-switch-nightlight ;;
        *Bar*)                   pkill -SIGUSR1 waybar ;;
        *Screensaver*)       $OMARCHY_BIN_PATH/omarchy-launch-screensaver ;;
        *Idle*)              $OMARCHY_BIN_PATH/omarchy-toggle-idle ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_style_menu() {
    case $(menu "Style" "¯»Å  Theme\n¾░©î  Colors\n¯ÖÖ  Font\n´Ç¥  Background\n´ìÖ  Hyprland") in
        *Theme*)      show_theme_menu ;;
        *Colors*)     show_colors_menu ;;
        *Font*)       show_font_menu ;;
        *Background*) hypr-switch-wallpaper ;;
        *Hyprland*)   edit_file $HOME/.config/hypr/looknfeel.conf ;;
        *) show_main_menu ;;
    esac
}

show_theme_menu() {
    local temas=(Square Circle Underscore Mac Float Tahoe KDE)
    local current_theme=$(grep import $HOME/.config/waybar/style.css | grep themes | cut -d "/" -f 2)

    local opts=""
    for i in "${temas[@]}"; do
        if [ "${i,,}" = "$current_theme" ]; then
            opts="$opts<i>$i</i>\n"
        else
            opts="$opts$i\n"
        fi
    done
    local theme=$(menu "Theme" "$opts")

    if [[ -n "$theme" ]]; then
        hypr-switch-theme $theme
    else
        back_to show_style_menu
    fi
}

show_colors_menu() {
    local temas=(Catppuccin Catppuccin-Latte Dracula Nord Nord-Frost)
    local current_theme=$(grep import $HOME/.config/waybar/style.css | grep colors | tr -d '"' | tr -d ';' | cut -d / -f 2 | cut -d . -f 1)

    local opts=""
    for i in "${temas[@]}"; do
        if [ "${i,,}" = "$current_theme" ]; then
            opts="$opts<i>$i</i>\n"
        else
            opts="$opts$i\n"
        fi
    done
    local theme=$(menu "Colors" "$opts")

    if [[ -n "$theme" ]]; then
        hypr-switch-colors $theme
    else
        back_to show_style_menu
    fi
}

show_font_menu() {
    local kitty_conf=$HOME/.config/kitty/kitty.conf
    local current_font=$(grep ^font_family $kitty_conf | sed 's/^font_family  *//')
    local opts=$(fc-list :spacing=100 -f "%{family[0]}\n" | sort -u | gawk '{print "<span font_family=\"" $0 "\">" $0 "</span>"}')
    local font=$(menu "$current_font" "$opts")

    if [[ -n "$font" ]]; then
        hypr-switch-font "$font"
    else
        back_to show_style_menu
    fi
}

show_setup_menu() {
    case $(menu "Setup" "¯ÿò  Configs\n¯ÿ©  Audio\n´ç½  Wifi\n¾░é»  Bluetooth\n¾░ì╣  Monitors\n¾░É¬  Printers\n´ä£  Keybindings\n¯¥║  Input\n¾░êÀ  Fingerprint\n¯¼æ  Fido2") in
        *Configs*)     hypr-edit-config ;;
        *Audio*)       terminal alsamixer ;;
        *Wifi*)        hypr-nmcli-rofi ;;
        *Bluetooth*)   blueman-manager ;;
        *Monitors*)    hypr-switch-monitor ;;
        *Printers*)    webapp "http://localhost:631" ;;
        *Keybindings*) [ $DESKTOP_SESSION = "bspwm" ] && edit_file $HOME/.config/sxhkd/sxhkdrc || edit_file $HOME/.config/hypr/keybinds.conf ;;
        *Input*)       edit_file $HOME/.config/hypr/input.conf ;;
        *Fingerprint*) terminal $OMARCHY_BIN_PATH/omarchy-setup-fingerprint ;;
        *Fido2*)       terminal $OMARCHY_BIN_PATH/omarchy-setup-fido2 ;;
        *) show_main_menu ;;
    esac
}

show_update_menu() {
    case $(menu "Update" "´Çí  Update\n¾░ëë  Install package\n¾░¡î  Remove package") in
        *Update*)  present_terminal hypr-do-update ;;
        *Install*) terminal "hypr-pkg-install; hypr-show-done" ;;
        *Remove*)  terminal "hypr-pkg-remove; hypr-show-done" ;;
        *) show_main_menu ;;
    esac
}

show_system_menu() {
    case $(menu "System" "¯®Á Lock\n¾░ù¢ Logout\n¾░ÉÑ Power Off\n´èî Suspend\n¯½Æ Restart") in
        *Lock*)       hyprlock ;;
        *Logout*)     hyprctl dispatch exit ;;
        *Power\ Off*) systemctl poweroff ;;
        *Suspend*)    systemctl suspend ;;
        *Restart*)    systemctl reboot ;;
        *) show_main_menu ;;
    esac
}

show_main_menu() {
    go_to_menu "$(menu "Start" "¾░Ç╗  Apps\n¯®¡  Search\n¯¬ñ  Learn\n¯»Å  Style\n¾▒ô×  Trigger\n¯ÿò  Setup\n´Çí  Update\n¯®┤  About\n´Çæ  System")"
}

go_to_menu() {
    case "${1,,}" in
        *apps*)       rofi -i -show drun -show-icons -theme layout-apps;;
        *search*)     hypr-search-home ;;
        *learn*)      show_learn_menu ;;
        *trigger*)    show_trigger_menu ;;
        *capture*)    show_capture_menu ;;
        *toggle*)     show_toggle_menu ;;
        *style*)      show_style_menu ;;
        *setup*)      show_setup_menu ;;
        *do-update*)  present_terminal hypr-do-update ;;
        *update*)     show_update_menu ;;
        *about*)      terminal "fastfetch && read -n 1 -s" ;;
        *system*)
            case $DESKTOP_SESSION in
                bspwm) $HOME/.config/rofi/powermenu/powermenu.sh ;;
                *)     show_system_menu ;;
                # *)     wlogout -b 5 ;;
            esac
            ;;
    esac
}

if [ -n "$1" ]; then
    go_to_menu "$1"
else
    show_main_menu
fi
