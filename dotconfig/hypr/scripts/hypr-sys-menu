#!/bin/bash

TERMINAL=kitty
SCRIPT_PATH=$XDG_CONFIG_HOME/hypr/scripts
export PATH="$SCRIPT_PATH:$PATH"

menu() {
    hypr-sys-show-menu "$1" "$2"
}

terminal() {
    $TERMINAL --class hypr-sys-menu --title=Fedora bash -c "$1"
}

present_terminal() {
    local cmd="$*"
    $TERMINAL --class hypr-sys-menu bash -c "hypr-show-logo; $cmd; hypr-show-done"
}

edit_file() {
    notify-send -u low "Editing config file" "$1"
    $TERMINAL nvim "$1"
}

back_to() {
    "$1"
}

webapp() {
    brave-browser --password-store=basic --new-window --app=$1
    # flatpak run com.brave.Browser --password-store=basic --new-window --app=$1
}

show_learn_menu() {
    # case $(menu "Learn" "п„ң  Keybindings\nпҗ…  Omarchy\nпҚҷ  Hyprland\nпҚ•  Bspwm\nоҜ¶  Waybar\nоҜ¶  Polybar\nпӮҜ  NerdFonts\nу°ЈҮ  Arch\nоҡ®  Neovim\nуұҶғ  Bash") in
    case $(menu "Learn" "п„ң  Keybindings\nпҗ…  Omarchy\nпҚҷ  Hyprland\nоҜ¶  Waybar\nпӮҜ  NerdFonts\nу°ЈҮ  Arch\nоҡ®  Neovim\nуұҶғ  Bash") in
        *Keybindings*) hypr-show-keybinds ;;
        *Omarchy*)     webapp "https://manuals.omamix.org/2/the-omarchy-manual" ;;
        *Hyprland*)    webapp "https://wiki.hypr.land/" ;;
        *Bspwm*)       webapp "https://github.com/baskerville/bspwm/wiki" ;;
        *Waybar*)      webapp "https://github.com/Alexays/Waybar/wiki" ;;
        *Polybar*)     webapp "https://github.com/polybar/polybar/wiki" ;;
        *NerdFonts*)   webapp "https://www.nerdfonts.com/cheat-sheet" ;;
        *Arch*)        webapp "https://wiki.archlinux.org/title/Main_page" ;;
        *Bash*)        webapp "https://devhints.io/bash" ;;
        *Neovim*)      webapp "https://www.lazyvim.org/keymaps" ;;
        *) show_main_menu ;;
    esac
}

show_trigger_menu() {
    case "$(menu "Trigger" "пҖ°  Capture\nпҲ…  Toggle")" in
        *Capture*) show_capture_menu ;;
        *Toggle*)  show_toggle_menu ;;
        *) show_main_menu ;;
    esac
}

show_capture_menu() {
    case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ғү  Color") in
        *Screenshot*)   show_screenshot_menu ;;
        *Screenrecord*) show_screenrecord_menu ;;
        *Color*)        pkill hyprpicker || hyprpicker -a ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_screenshot_menu() {
    case $(menu "Screenshot" "у°©¬   Region to clipboard\nу°©¬   Region to file\nу°№‘    Display to clipboard\nу°№‘    Display to file") in
        *Region\ to\ clipboard*) hypr-cmd-screenshot clipboard ;;
        *Region\ to\ file*)      hypr-cmd-screenshot region ;;
        *Display\ to\ file*)     hypr-cmd-screenshot ;;
        *) show_capture_menu ;;
    esac
}

show_screenrecord_menu() {
    case $(menu "Screenrecord" "у°©¬  Region\nу°№‘  Display") in
        *Region*)  $OMARCHY_BIN_PATH/omarchy-cmd-screenrecord ;;
        *Display*) $OMARCHY_BIN_PATH/omarchy-cmd-screenrecord output ;;
        *) show_capture_menu ;;
    esac
}

show_toggle_menu() {
    # wifi_status=$(nmcli radio wifi)
    # bt_status=$(if $(bluetoothctl show | grep -q "Powered: no" > /dev/null ); then echo "disabled"; else echo "enabled"; fi)
    # power_status=$(tuned-adm active | cut -d " " -f 4)
    # keyb_status=$(setxkbmap -query | grep layout | awk '{print $2}')
    case $(menu "Toggle" "пҮ«  Wifi\nу°ӮҜ  Bluetooth\nпғ§  Power Management\nп„ң  Keyboard Layout\nу°Әӣ  Keyboard ControlCaps\nуұ„„  Screensaver\nу°”Һ  Nightlight\nуұ«–  Idle Lock\nу°Қң  Top Bar") in
        *Wifi*)                  hypr-switch-wifi ;;
        *Bluetooth*)             hypr-bluetooth --toggle ;;
        *Power\ Management*)     show_power_management ;;
        *Keyboard\ Layout*)      hypr-switch-keyboard-layout ;;
        *Keyboard\ ControlCaps*) hypr-switch-controlcaps ;;
        *Nightlight*)            hypr-switch-nightlight ;;
        *Bar*)                   pkill -SIGUSR1 waybar ;;
        *Screensaver*)       $OMARCHY_BIN_PATH/omarchy-launch-screensaver ;;
        *Idle*)              $OMARCHY_BIN_PATH/omarchy-toggle-idle ;;
        *) back_to show_trigger_menu ;;
    esac
}

show_power_management() {
    case $(menu "Power Management" "пүҺ  Balanced\nпүҺ  Balanced Battery\nпғ§  Performance\nпҒ¬  Power Saver") in
        *Balanced\ Battery*) tuned-adm profile balanced-battery ;;
        *Balanced*)          tuned-adm profile balanced ;;
        *Performance*)       tuned-adm profile throughput-performance ;;
        *Power\ Saver*)      tuned-adm profile powersave ;;
        *) back_to show_toggle_menu ;;
    esac
}

show_style_menu() {
    case $(menu "Style" "оҜ¶  Bar Layout\nу°ёҢ  Colors\nоҷҷ  Font\nпҖҫ  Background\nпҚҷ  Hyprland") in
        *Bar\ Layout*) hypr-switch-theme ;;
        *Colors*)      hypr-switch-colors ;;
        *Font*)        hypr-switch-font ;;
        *Background*)  hypr-switch-wallpaper ;;
        *Hyprland*)    edit_file $XDG_CONFIG_HOME/hypr/lua/looknfeel.lua ;;
        *) show_main_menu ;;
    esac
}

show_setup_menu() {
    case $(menu "Setup" "оҳ•  Configs\nоҳё  Audio\nпҮ«  Wifi\nу°ӮҜ  Bluetooth\nу°Қ№  Monitors\nу°җӘ  Printers\nп„ң  Keybindings\nоҫә  Input\nу°Ҳ·  Fingerprint\nо¬‘  Fido2") in
        *Configs*)      hypr-edit-config ;;
        *Audio*)        terminal wiremix ;;
        *Wifi*)         hypr-nmcli-rofi ;;
        *Bluetooth*)    blueman-manager ;;
        *Monitors*)     hypr-switch-monitor ;;
        *Printers*)     webapp "http://localhost:631" ;;
        *Keybindings*)  [ $DESKTOP_SESSION = "bspwm" ] && edit_file $XDG_CONFIG_HOME/sxhkd/sxhkdrc || edit_file $XDG_CONFIG_HOME/hypr/lua/keybinds.lua ;;
        *Input*)        edit_file $XDG_CONFIG_HOME/hypr/lua/input.lua ;;
        *Fingerprint*)  terminal $OMARCHY_BIN_PATH/omarchy-setup-fingerprint ;;
        *Fido2*)        terminal $OMARCHY_BIN_PATH/omarchy-setup-fido2 ;;
        *) show_main_menu ;;
    esac
}

show_update_menu() {
    case $(menu "Update" "пҖЎ  Update\nу°үү  Install package\nу°ӯҢ  Remove package") in
        *Update*)   present_terminal hypr-do-update ;;
        *Install*)  terminal "hypr-pkg-install; hypr-show-done" ;;
        *Remove*)   terminal "hypr-pkg-remove; hypr-show-done" ;;
        *) show_main_menu ;;
    esac
}

show_system_menu() {
    case $(menu "System" "о©ө Lock\nу°—Ҫ Logout\nу°җҘ Power Off\nпҠҢ Suspend\nо«’ Restart") in
        *Lock*)        hyprlock ;;
        *Logout*)      loginctl terminate-user $USER ;;
        *Power\ Off*)  systemctl poweroff ;;
        *Suspend*)     systemctl suspend ;;
        *Restart*)     systemctl reboot ;;
        *) show_main_menu ;;
    esac
}

show_main_menu() {
    go_to_menu "$(menu "Start" "у°Җ»  Apps\nо©ӯ  Search\nоҜҸ  Style\nоӘӨ  Learn\nуұ“һ  Trigger\nоҳ•  Setup\nпҖЎ  Update\nо©ҙ  About\nпҖ‘  System")"
}

go_to_menu() {
    case "${1,,}" in
        *apps*)       rofi -i -show drun -show-icons -theme layout-apps;;
        *search*)     hypr-search-home ;;
        *learn*)      show_learn_menu ;;
        *trigger*)    show_trigger_menu ;;
        *capture*)    show_capture_menu ;;
        *toggle*)     show_toggle_menu ;;
        *style*)      show_style_menu ;;
        *setup*)      show_setup_menu ;;
        *do-update*)  present_terminal hypr-do-update ;;
        *update*)     show_update_menu ;;
        *about*)      terminal "fastfetch && read -n 1 -s" ;;
        *system*)     show_system_menu ;;
    esac
}

if [ -n "$1" ]; then
    go_to_menu "$1"
else
    show_main_menu
fi
