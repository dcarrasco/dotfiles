#!/bin/bash

OPCIONES=$(virsh --connect qemu:///system list --all | cut -c 7- | sed -E 's/[ ]+/ /g' | grep -v Nombre | grep -v "\-\-" | grep -E -v "^$" | awk -F " " '{ print $1 " (" $2 $3 ")" }')

theme="prompt{enabled:false;} entry{placeholder:\"Start VM...\";} window{width:400px; height:600px;}"
VM=$(printf "$OPCIONES" | rofi -dmenu -p "" -theme-str "$theme" | cut -d " " -f 1)

echo $VM

if [ -n "$VM" ]; then
    ~/.config/hypr/scripts/hypr-start-vm $VM
fi
