#!/bin/bash

waybar_style=$XDG_CONFIG_HOME/waybar/colors.css
hypr_conf=$XDG_CONFIG_HOME/hypr/conf/theme.conf
hypr_lua=$XDG_CONFIG_HOME/hypr/lua/theme.lua
rofi_colors=$XDG_CONFIG_HOME/rofi/themes/colors.rasi

create_config_file() {
    if [ ! -f "$1" ]; then
        cp "${1}.orig" "$1"
    fi
}

create_config_file "$waybar_style"
create_config_file "$hypr_conf"
create_config_file "$hypr_lua"
create_config_file "$rofi_colors"

current_theme() {
    grep import $waybar_style | grep colors | tr -d '"' | tr -d ';' | cut -d / -f 2 | cut -d . -f 1
}

change_theme() {
    # waybar
    sed -i "s/\"colors\/.*\.css\"/\"colors\/$1.css\"/" $waybar_style

    # hyprland
    sed -i "s/\$theme = .*/\$theme = $1/" $hypr_conf
    sed -i "s/HYPR\.theme_name.*/HYPR.theme_name = \"$1\"/" $hypr_lua

    # rofi
    sed -i "s/^@import \"themes\/colors\/.*\.rasi\"/@import \"themes\/colors\/$1.rasi\"/" $rofi_colors

    # bspwm
    # sed -i "s/^source \$HOME\/\.config\/bspwm\/themes\/.*/source \$HOME\/.config\/bspwm\/themes\/$1/" $HOME/.config/bspwm/bspwmrc

    # polybar
    # sed -i "s/include-file = .*\/config.ini/include-file = \$HOME\/\.config\/polybar\/themes\/$1\/config.ini/" $HOME/.config/polybar/config.ini

}

if [ -n "$1" ]; then
    theme=$1
else
    temas=(Catppuccin Catppuccin-Latte Dracula Nord Nord-Frost)

    opts=""
    for i in "${temas[@]}"; do
        if [ "${i,,}" = "$(current_theme)" ]; then
            opts="$opts<i>$i</i>\n"
        else
            opts="$opts$i\n"
        fi
    done
    theme=$(echo -e $opts | rofi -dmenu -markup-rows -i -format p -p "")
fi

if [ -n "$theme" ]; then
    change_theme ${theme,,}
    [ "$DESKTOP_SESSION" = "bspwm" ] && bspc wm --restart || $HOME/.config/hypr/scripts/hypr-restore-waybar
    notify-send -u low "Colors" "Change colors to $theme"
fi

