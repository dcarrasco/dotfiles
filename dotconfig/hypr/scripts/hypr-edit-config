#!/bin/bash

#            _ _ _                         __ _
#    ___  __| (_) |_       ___ ___  _ __  / _(_) __ _
#   / _ \/ _` | | __|____ / __/ _ \| '_ \| |_| |/ _` |
#  |  __/ (_| | | ||_____| (_| (_) | | | |  _| | (_| |
#   \___|\__,_|_|\__|     \___\___/|_| |_|_| |_|\__, |
#                                               |___/

arch=(\
    "waybar/config.jsonc" \
    "waybar/style.css" \
    "hypr/hyprland.lua" \
    "hypr/lua/envs.lua" \
    "hypr/lua/autostart.lua" \
    "hypr/lua/keybinds.lua" \
    "hypr/lua/monitors.lua" \
    "hypr/lua/input.lua" \
    "hypr/lua/looknfeel.lua" \
    "hypr/lua/rules.lua" \
    # "hypr/conf/envs.conf" \
    # "hypr/conf/autostart.conf" \
    # "hypr/conf/keybinds.conf" \
    # "hypr/conf/monitors.conf" \
    # "hypr/conf/input.conf" \
    # "hypr/conf/looknfeel.conf" \
    # "hypr/conf/rules.conf" \
    "hypr/hyprlock.conf" \
    "hypr/hypridle.conf" \
    "hypr/scripts/hypr-edit-config" \
    "hypr/scripts/hypr-sys-menu" \
    "wlogout/layout" \
    "wlogout/style.css" \
    "kitty/kitty.conf" \
    "alacritty/alacritty.toml" \
    # "bspwm/bspwmrc" \
    # "bspwm/picom.conf" \
    # "sxhkd/sxhkdrc" \
    # "polybar/config.ini" \
    # "polybar/themes/nord/config.ini" \
    # "sway/config" \
    "rofi/config.rasi" \
    # "wofi/config" \
    # "wofi/style.css" \
    # "dunst/dunstrc" \
    "mako/config" \
    "nvim/lua/daniel/" \
    "starship.toml" \
    "../.tmux.conf" \
    "zsh/.zshrc" \
    "../.zshenv" \
)

config_dir=$HOME/.config

listado=""
for file in ${arch[@]}; do
    case $(echo $file | cut -d "/" -f 1) in
        *waybar*)    icon="´âë   " ;;
        *polybar*)   icon="´âë   " ;;
        *hypr*)      icon="´ìÖ   " ;;
        *wlogout*)   icon="¾░ìâ   " ;;
        *kitty*)     icon="¯¬à   " ;;
        *alacritty*) icon="¯¬à   " ;;
        *starship*)  icon="¯¬à   " ;;
        *bspwm*)     icon="¯¼ú   " ;;
        *sway*)      icon="¯¼ú   " ;;
        *rofi*)      icon="¯¼ú   " ;;
        *wofi*)      icon="¯¼ú   " ;;
        *sxhkd*)     icon="´ä£   " ;;
        *dunst*)     icon="´ë║   " ;;
        *mako*)      icon="´ë║   " ;;
        *nvim*)      icon="¯Ü«   " ;;
        *)           icon="¯®╗   " ;;
    esac
    listado+="$icon$file\n"
done

file=$(echo -e "$listado" | rofi -dmenu -i -p "Edit config")

if [[ -n $file ]]; then
    icon=$(echo -e "$file" | sed "s/  */ /g" | cut -d " " -f 1)
    file=$(echo -e "$file" | sed "s/  */ /g" | cut -d " " -f 2)
    notify-send -u low "Editing config file" "$icon   $file..."
    cd "$(dirname $config_dir/$file)"
    kitty nvim "$config_dir/$file"
fi

