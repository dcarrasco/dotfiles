#!/bin/bash

#            _ _ _                         __ _
#    ___  __| (_) |_       ___ ___  _ __  / _(_) __ _
#   / _ \/ _` | | __|____ / __/ _ \| '_ \| |_| |/ _` |
#  |  __/ (_| | | ||_____| (_| (_) | | | |  _| | (_| |
#   \___|\__,_|_|\__|     \___\___/|_| |_|_| |_|\__, |
#                                               |___/

arch=(\
    "waybar/config.jsonc" \
    "waybar/style.css" \
    "hypr/hyprland.lua" \
    "hypr/lua/envs.lua" \
    "hypr/lua/autostart.lua" \
    "hypr/lua/keybinds.lua" \
    "hypr/lua/monitors.lua" \
    "hypr/lua/input.lua" \
    "hypr/lua/looknfeel.lua" \
    "hypr/lua/rules.lua" \
    # "hypr/conf/envs.conf" \
    # "hypr/conf/autostart.conf" \
    # "hypr/conf/keybinds.conf" \
    # "hypr/conf/monitors.conf" \
    # "hypr/conf/input.conf" \
    # "hypr/conf/looknfeel.conf" \
    # "hypr/conf/rules.conf" \
    "hypr/hyprlock.conf" \
    "hypr/hypridle.conf" \
    "hypr/hyprpaper.conf" \
    "hypr/scripts/hypr-edit-config" \
    "hypr/scripts/hypr-sys-menu" \
    "wlogout/layout" \
    "wlogout/style.css" \
    "kitty/kitty.conf" \
    "alacritty/alacritty.toml" \
    # "bspwm/bspwmrc" \
    # "bspwm/picom.conf" \
    # "sxhkd/sxhkdrc" \
    # "polybar/config.ini" \
    # "polybar/themes/nord/config.ini" \
    # "sway/config" \
    "rofi/config.rasi" \
    # "wofi/config" \
    # "wofi/style.css" \
    # "dunst/dunstrc" \
    "mako/config" \
    "nvim/lua/daniel/" \
    "starship/starship.toml" \
    "tmux/tmux.conf" \
    "zsh/.zshrc" \
    "zsh/.zshenv" \
)

config_dir=$XDG_CONFIG_HOME

listado=""
for file in ${arch[@]}; do
    case $(echo $file | cut -d "/" -f 1) in
        *waybar*)    icon="´âë   " ;;
        *polybar*)   icon="´âë   " ;;
        *hypr*)      icon="´ıÖ   " ;;
        *wlogout*)   icon="¾░ıâ   " ;;
        *kitty*)     icon="¯¬à   " ;;
        *alacritty*) icon="¯¬à   " ;;
        *starship*)  icon="´åù   " ;;
        *tmux*)      icon="¯»ê   " ;;
        *bspwm*)     icon="¯¼ú   " ;;
        *sway*)      icon="¯¼ú   " ;;
        *rofi*)      icon="¯¼ú   " ;;
        *wofi*)      icon="¯¼ú   " ;;
        *sxhkd*)     icon="´ä£   " ;;
        *dunst*)     icon="´ë║   " ;;
        *mako*)      icon="´ë║   " ;;
        *nvim*)      icon="¯Ü«   " ;;
        *zsh*)       icon="¯»ç   " ;;
        *)           icon="¯®╗   " ;;
    esac
    listado+="$icon$file\n"
done

theme="prompt{enabled:false;} entry{placeholder:\"Edit config...\";} window{width:22%;}"
file=$(echo -e "$listado" | rofi -dmenu -i -theme-str "$theme")

if [[ -n $file ]]; then
    icon=$(echo -e "$file" | sed "s/  */ /g" | cut -d " " -f 1)
    file=$(echo -e "$file" | sed "s/  */ /g" | cut -d " " -f 2)
    notify-send -u low "Editing config file" "$icon   $file..."
    cd "$(dirname $XDG_CONFIG_HOME/$file)"
    kitty nvim "$XDG_CONFIG_HOME/$file"
fi

